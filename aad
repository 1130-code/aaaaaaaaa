    if ncConn then ncConn:Disconnect() ncConn = nil end
end

-- [ 3. 二段跳躍 ]
local djConn
local function startDoubleJump()
    getgenv().config.doubleJumpEnabled = true
    if djConn then djConn:Disconnect() end
    local jumpCount = 0
    djConn = UserInputService.JumpRequest:Connect(function()
        if not getgenv().config.doubleJumpEnabled then return end
        local hum = GetHum()
        if hum then
            if hum:GetState() == Enum.HumanoidStateType.Freefall then
                if jumpCount < 1 then
                    hum:ChangeState(Enum.HumanoidStateType.Jumping)
                    jumpCount = jumpCount + 1
                end
            else
                jumpCount = 0
