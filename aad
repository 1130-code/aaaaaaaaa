local function ForceCleanOldGUIs()
    pcall(function()
        local guiName = 'RiotShieldMasterGUI'
        local playerGui = LocalPlayer:FindFirstChild("PlayerGui")
        if playerGui and playerGui:FindFirstChild(guiName) and playerGui:FindFirstChild(guiName) ~= ScreenGui then
            playerGui[guiName]:Destroy()
        end
        local target = CoreGui:FindFirstChild("RobloxGui") or CoreGui
        if target and target:FindFirstChild(guiName) and target:FindFirstChild(guiName) ~= ScreenGui then
            target[guiName]:Destroy()
        end
        if gethui then
            local hui = gethui()
            if hui and hui:FindFirstChild(guiName) and hui:FindFirstChild(guiName) ~= ScreenGui then
                hui[guiName]:Destroy()
            end
        end
    end)
end
