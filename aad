-- [ 1. 無減速繞過 (Riot Bypass) ]
local bypassConn
local function ToggleRiotBypass(state)
    getgenv().ShieldConfig.bypassEnabled = state
    if bypassConn then bypassConn:Disconnect() bypassConn = nil end
    
    if state then
        bypassConn = RunService.Heartbeat:Connect(function()
            local hum = GetHum()
            local shield = GetShield()
            -- 如果裝備了盾牌，強制維持正常跑速並移除可能產生的減速 BodyVelocity
            if hum and shield then
                if hum.WalkSpeed < getgenv().ShieldConfig.customWalkSpeed then
                    hum.WalkSpeed = getgenv().ShieldConfig.customWalkSpeed
                end
                
                -- 清理盾牌可能附加的物理減速器
                local hrp = GetHRP()
                if hrp then
                    for _, v in ipairs(hrp:GetChildren()) do
                        if v:IsA("BodyVelocity") and v.Name:lower():find("shield") then
                            v:Destroy()
                        end
                    end
                end
            end
        end)
        table.insert(getgenv().ShieldConnections, bypassConn)
    end
end

-- [ 2. 自動範圍打擊 (Riot Abuser) ]
local abuserConn
local function ToggleRiotAbuser(state)
    getgenv().ShieldConfig.abuserEnabled = state
    if abuserConn then abuserConn:Disconnect() abuserConn = nil end
    
    if state then
        abuserConn = RunService.Heartbeat:Connect(function()
            local shield = GetShield()
            local myHRP = GetHRP()
            if not shield or not myHRP then return end
            
            local handle = shield:FindFirstChild("Handle") or shield:FindFirstChildOfClass("BasePart")
            if not handle then return end

            -- 掃描附近敵人並自動使用盾牌 Hitbox 進行判定觸發
            for _, plr in ipairs(Players:GetPlayers()) do
                if plr ~= LocalPlayer and plr.Character then
                    local targetHRP = GetHRP(plr)
                    local targetHum = GetHum(plr)
                    if targetHRP and targetHum and targetHum.Health > 0 then
                        local dist = (targetHRP.Position - myHRP.Position).Magnitude
                        if dist <= getgenv().ShieldConfig.abuserRadius then
                            -- 利用 firetouchinterest 模擬盾牌撞擊
                            if firetouchinterest then
                                firetouchinterest(handle, targetHRP, 0)
                                firetouchinterest(handle, targetHRP, 1)
                            end
                        end
                    end
                end
            end
        end)
        table.insert(getgenv().ShieldConnections, abuserConn)
    end
end

-- [ 3. 巨型力場護盾 (Giant Shield Aura) ]
local giantConn
local function ToggleGiantShield(state)
    getgenv().ShieldConfig.giantShieldEnabled = state
    if giantConn then giantConn:Disconnect() giantConn = nil end
    
    if state then
        giantConn = RunService.Heartbeat:Connect(function()
            local shield = GetShield()
            if shield then
                local handle = shield:FindFirstChild("Handle") or shield:FindFirstChildOfClass("BasePart")
                if handle then
                    if not originalShieldProps[handle] then
                        originalShieldProps[handle] = {
                            Size = handle.Size,
                            Transparency = handle.Transparency,
                            Massless = handle.Massless
                        }
                    end
                    
                    local sizeVal = getgenv().ShieldConfig.giantSize
                    handle.Size = Vector3.new(sizeVal, sizeVal, sizeVal)
                    handle.Transparency = 0.6
                    handle.Massless = true
                    handle.CanCollide = false
                    -- 修改顏色讓力場看起來更酷 (如果允許的話)
                    pcall(function() handle.BrickColor = BrickColor.new("Cyan") handle.Material = Enum.Material.ForceField end)
                end
            end
        end)
        table.insert(getgenv().ShieldConnections, giantConn)
    else
        -- 還原盾牌屬性
        for handle, props in pairs(originalShieldProps) do
            if handle and handle.Parent then
                handle.Size = props.Size
                handle.Transparency = props.Transparency
                handle.Massless = props.Massless
                pcall(function() handle.Material = Enum.Material.Plastic end)
            end
        end
        originalShieldProps = {}
    end
end

-- [ 4. 智能自動裝備 (Smart Auto Equip) ]
local autoEquipConn
local function ToggleAutoEquip(state)
    getgenv().ShieldConfig.autoEquipEnabled = state
    if autoEquipConn then autoEquipConn:Disconnect() autoEquipConn = nil end
    
    if state then
        autoEquipConn = RunService.Heartbeat:Connect(function()
            local hum = GetHum()
            if hum and hum.Health > 0 and hum.Health <= getgenv().ShieldConfig.autoEquipHealth then
                if not GetShield() then
                    local backpackShield = GetShieldFromBackpack()
                    if backpackShield and hum.Parent then
                        hum:EquipTool(backpackShield)
                    end
                end
            end
        end)
        table.insert(getgenv().ShieldConnections, autoEquipConn)
    end
end

-- [ 5. 無視敵人盾牌 (Ignore Enemy Shields) ]
local ignoreShieldsConn
local function ToggleIgnoreEnemyShields(state)
    getgenv().ShieldConfig.ignoreEnemyShields = state
    if ignoreShieldsConn then ignoreShieldsConn:Disconnect() ignoreShieldsConn = nil end

    if state then
        ignoreShieldsConn = RunService.Heartbeat:Connect(function()
            for _, plr in ipairs(Players:GetPlayers()) do
                if plr ~= LocalPlayer and plr.Character then
                    for _, tool in ipairs(plr.Character:GetChildren()) do
                        if tool:IsA("Tool") and (tool.Name:lower():find("shield") or tool.Name:lower():find("riot")) then
                            for _, part in ipairs(tool:GetDescendants()) do
                                if part:IsA("BasePart") then
                                    if not originalEnemyShieldProps[part] then
                                        originalEnemyShieldProps[part] = {
                                            CanCollide = part.CanCollide,
                                            CanTouch = part.CanTouch
                                        }
                                    end
                                    part.CanCollide = false
                                    part.CanTouch = false
                                end
                            end
                        end
                    end
                end
            end
        end)
        table.insert(getgenv().ShieldConnections, ignoreShieldsConn)
    else
        for part, props in pairs(originalEnemyShieldProps) do
            if part and part.Parent then
                part.CanCollide = props.CanCollide
                part.CanTouch = props.CanTouch
            end
        end
        originalEnemyShieldProps = {}
    end
end

