    button.Text = "  " .. name
    button.TextColor3 = Color3.fromRGB(150, 150, 160)
    button.TextSize = 11
    button.Font = Enum.Font.GothamSemibold
    button.TextXAlignment = Enum.TextXAlignment.Left
    button.Parent = SideBar
    
    local content = CreateTabContentFrame(name)
