local function startFly()
    getgenv().config.flyEnabled = true
    local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local hrp = char:WaitForChild("HumanoidRootPart")
    local hum = char:WaitForChild("Humanoid")
    
    local flyGyro = Instance.new("BodyGyro")
    flyGyro.P = 9e4
    flyGyro.maxTorque = Vector3.new(9e9, 9e9, 9e9)
    flyGyro.cframe = hrp.CFrame
    flyGyro.Parent = hrp
    
    local flyVelocity = Instance.new("BodyVelocity")
    flyVelocity.velocity = Vector3.new(0, 0.1, 0)
    flyVelocity.maxForce = Vector3.new(9e9, 9e9, 9e9)
    flyVelocity.Parent = hrp
    
    hum.PlatformStand = true
    
    local conn = RunService.RenderStepped:Connect(function()
        if not getgenv().config.flyEnabled then return end
        local camera = Workspace.CurrentCamera
        local moveDir = hum.MoveDirection
        local velocity = Vector3.zero
        
        if UserInputService:IsKeyDown(Enum.KeyCode.Space) then
            velocity = velocity + Vector3.new(0, getgenv().config.flySpeed, 0)
        elseif UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then
            velocity = velocity - Vector3.new(0, getgenv().config.flySpeed, 0)
        end
        
        if moveDir.Magnitude > 0 then
            velocity = velocity + (moveDir * getgenv().config.flySpeed)
        end
        
        flyVelocity.velocity = velocity
        flyGyro.cframe = camera.CFrame
    end)
    table.insert(getgenv().AllConnections, conn)
end

local function stopFly()
    getgenv().config.flyEnabled = false
    local char = LocalPlayer.Character
    if char then
        local hrp = char:FindFirstChild("HumanoidRootPart")
        local hum = char:FindFirstChild("Humanoid")
        if hrp then
            local gyro = hrp:FindFirstChildOfClass("BodyGyro")
            local vel = hrp:FindFirstChildOfClass("BodyVelocity")
            if gyro then gyro:Destroy() end
            if vel then vel:Destroy() end
        end
        if hum then hum.PlatformStand = false end
    end
end

-- 快速換彈優化：使用防重複狀態鎖
local isReloadingActive = false
local function startFastReload()
    if isReloadingActive then return end
    getgenv().config.fastReloadEnabled = true
    isReloadingActive = true
    task.spawn(function()
        while getgenv().config.fastReloadEnabled do
            pcall(function()
                local char = LocalPlayer.Character
                if char then
                    for _, v in ipairs(char:GetDescendants()) do
                        if v:IsA("NumberValue") and (v.Name:lower():find("reload") or v.Name:lower():find("cooldown")) then
                            v.Value = 0
                        end
                    end
                end
            end)
            task.wait(0.1)
        end
        isReloadingActive = false
    end)
end

local function stopFastReload()
    getgenv().config.fastReloadEnabled = false
end

-- 迴圈與遠端 Hooks 配置優化
local oldFireServer
local function applyDaggerBypass()
    if oldFireServer then return end
    pcall(function()
        oldFireServer = hookfunction(Instance.new("RemoteEvent").FireServer, newcclosure(function(self, ...)
            if not checkcaller() and getgenv().config.daggerBypass then
                local n = self.Name:lower()
                if (n:find("dagger") or n:find("knife") or n:find("throw") or n:find("blade")) then
                    local a = table.concat({ ... }, " "):lower()
                    if not (a:find(LocalPlayer.Name:lower()) or a:find("owner")) then return end
                end
            end
            return oldFireServer(self, ...)
        end))
    end)
end

