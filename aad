local function StripPartCollision(part)
    if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
        part.CanCollide = false
        part.CanTouch = false
    end
end

local function ExpandEnemyHitbox(char)
    if not char or char == LocalPlayer.Character then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if hrp then
        if not originalSizes[hrp] then originalSizes[hrp] = hrp.Size end
        hrp.Size = HITBOX_SIZE
        hrp.Transparency = 0.85
        hrp.BrickColor = BrickColor.new("Bright red")
        hrp.Material = Enum.Material.ForceField
        hrp.CanCollide = false
        hrp.CanTouch = true
    end
    for _, part in ipairs(char:GetDescendants()) do
        StripPartCollision(part)
    end
end

local function ExpandToolHitbox(tool)
    if tool:IsA("Tool") then
        myProjectiles[tool] = true
        for _, part in ipairs(tool:GetDescendants()) do
            if part:IsA("BasePart") and part.Name == "Handle" then
                if not originalProjSizes[part] then originalProjSizes[part] = part.Size end
                part.Size = HITBOX_SIZE
                part.Transparency = 0.8
                part.BrickColor = BrickColor.new("Cyan")
                part.Material = Enum.Material.ForceField
                part.Massless = true
                part.CanCollide = false
                part.CanTouch = true
                myProjectiles[part] = true
            end
        end
    end
end

local function MonitorEnemyArmorPenetration(enemyChar)
    if not enemyChar or enemyChar == LocalPlayer.Character then return end
    ExpandEnemyHitbox(enemyChar)
    
    local name = enemyChar.Name
    if oblivionEnemyConnections[name] then
        for _, c in ipairs(oblivionEnemyConnections[name]) do c:Disconnect() end
    end
    oblivionEnemyConnections[name] = {}
    
    local conn = enemyChar.DescendantAdded:Connect(function(part)
        if isOblivionActive then StripPartCollision(part) end
    end)
    table.insert(oblivionEnemyConnections[name], conn)
end

local function CheckAndMonitorModel(obj)
    if obj:IsA("Model") and obj ~= LocalPlayer.Character and obj:FindFirstChild("Humanoid") then
        MonitorEnemyArmorPenetration(obj)
    end
end

local function UpdateLocalCharacterCache(char)
    table.clear(myCharacterParts)
    if not char then return end
    
    local function registerPart(part)
        if part:IsA("BasePart") then
            if not table.find(myCharacterParts, part) then table.insert(myCharacterParts, part) end
            if isOblivionActive then
                if not originalPhysicalProperties[part] then
                    originalPhysicalProperties[part] = part.CustomPhysicalProperties
                end
                part.CustomPhysicalProperties = PhysicalProperties.new(math.huge, 0, 0, math.huge, math.huge)
                part.CanCollide = false
                if part:FindFirstAncestorOfClass("Tool") or part.Name:match("Hand") or part.Name:match("Arm") then
                    part.CanTouch = true
                else
                    part.CanTouch = false
                end
                part.Massless = true
            end
        end
    end

    for _, desc in ipairs(char:GetDescendants()) do registerPart(desc) end
    oblivionConnections.CharDescAdded = char.DescendantAdded:Connect(registerPart)
    oblivionConnections.CharDescRemoving = char.DescendantRemoving:Connect(function(part)
        local idx = table.find(myCharacterParts, part)
        if idx then table.remove(myCharacterParts, idx) end
    end)
end

local function ApplyOblivionSetups(char)
    if not char then return end
    local hum = char:WaitForChild("Humanoid", 3)
    local hrp = char:WaitForChild("HumanoidRootPart", 3)
    
    if not isOblivionActive then return end

    if hrp then
        pcall(function() sethiddenproperty(hrp, "NetworkIsSleeping", true) end)
        lastSafeCFrame = hrp.CFrame
    end

    if hum then
        hum.MaxHealth = math.huge
        hum.Health = math.huge
        if oblivionConnections.HealthLock then oblivionConnections.HealthLock:Disconnect() end
        oblivionConnections.HealthLock = hum:GetPropertyChangedSignal("Health"):Connect(function()
            if hum.Health < hum.MaxHealth and isOblivionActive then hum.Health = hum.MaxHealth end
        end)

        local badStates = {
            Enum.HumanoidStateType.Dead, Enum.HumanoidStateType.Ragdoll,
            Enum.HumanoidStateType.FallingDown, Enum.HumanoidStateType.Physics,
            Enum.HumanoidStateType.PlatformStanding, Enum.HumanoidStateType.Stunned,
            Enum.HumanoidStateType.Seated
        }
        for _, s in ipairs(badStates) do
            if originalStates[s] == nil then originalStates[s] = hum:GetStateEnabled(s) end
            hum:SetStateEnabled(s, false)
        end
    end

    if oblivionConnections.ToolEquip then oblivionConnections.ToolEquip:Disconnect() end
    oblivionConnections.ToolEquip = char.ChildAdded:Connect(ExpandToolHitbox)
    for _, tool in ipairs(char:GetChildren()) do ExpandToolHitbox(tool) end

    UpdateLocalCharacterCache(char)
end

LocalPlayer.CharacterAdded:Connect(function(char)
    originalPhysicalProperties = {}
    if isOblivionActive then
        task.spawn(function()
            task.wait(0.2)
            ApplyOblivionSetups(char)
        end)
    end
end)

