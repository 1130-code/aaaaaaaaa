-- [ 5. 飛刀 / 匕首 Metamethod 繞過 (最安全防崩潰方案) ]
local oldNamecall
local function applyDaggerBypass()
    if oldNamecall or not hookmetamethod then return end
    pcall(function()
        oldNamecall = hookmetamethod(game, "__namecall", newcclosure(function(self, ...)
            local method = getnamecallmethod()
            if not checkcaller() and method == "FireServer" and getgenv().config.daggerBypass then
                local n = self.Name:lower()
                if (n:find("dagger") or n:find("knife") or n:find("throw") or n:find("blade")) then
                    local a = table.concat({ ... }, " "):lower()
                    if not (a:find(LocalPlayer.Name:lower()) or a:find("owner")) then return end
                end
            end
            return oldNamecall(self, ...)
        end))
    end)
end

