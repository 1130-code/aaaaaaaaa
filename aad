    button.MouseButton1Click:Connect(function()
        if activeTab then
            tabs[activeTab].Button.TextColor3 = Color3.fromRGB(150, 150, 160)
            tabs[activeTab].Button.BackgroundTransparency = 1
            tabs[activeTab].Content.Visible = false
        end
        activeTab = name
        button.TextColor3 = Color3.fromRGB(0, 255, 170)
        button.BackgroundColor3 = Color3.fromRGB(25, 25, 35)
        button.BackgroundTransparency = 0.5
        content.Visible = true
    end)
end

