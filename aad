-- ==========================================
-- [ 核心奇點參數 (量子跳躍) ]
-- ==========================================
-- 使用 9e8 而非 math.huge，因為真正的 math.huge 在 CFrame 運算中容易產生 NaN 導致本地客戶端閃退
-- 9e8 (9億) 已經遠遠超出了 Roblox 所有射線檢測與地圖的極限，等同於無限大
local INF_VAL = 9e8 
local FORCEFIELD_RADIUS = 150 

local isActive = false
local realCFrame = nil
local overlapParams = OverlapParams.new()
overlapParams.FilterType = Enum.RaycastFilterType.Exclude

-- 連接池
